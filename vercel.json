{
  "rewrites": [
    {
      "source": "/api/:match*",
      "destination": "https://aetherlog-backend.onrender.com/api/:match*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite"
}
